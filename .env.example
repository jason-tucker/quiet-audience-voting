# Database — SQLite file location
# Local dev: file:./prisma/dev.db
# Production (Docker): file:/app/data/prod.db
DATABASE_URL="file:./prisma/dev.db"

# JWT secret for admin auth cookie. Generate a random 32+ char string.
# On Windows: [Convert]::ToBase64String([byte[]] (1..32 | % { Get-Random -Max 256 }))
# IMPORTANT: the server refuses to start with this placeholder value.
JWT_SECRET="change-me-to-a-random-32-plus-char-string"

# Initial admin password used on first login when no password has been set
# in settings. The literal string "changeme" is rejected at login time —
# pick a real password before the first login.
INITIAL_ADMIN_PASSWORD="changeme"

# Public URL — used for absolute URLs in metadata and as an alternate
# accepted Origin on /api/login. Update per environment.
# Local: http://localhost:3000
# Dev:   https://dev.qcffpoll.com
# Prod:  https://qcffpoll.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "true" only when the app sits behind a proxy that overwrites the
# x-forwarded-for / x-real-ip headers (e.g. Cloudflare Tunnel, nginx).
# Without this, those headers are ignored and the audit log records the
# IP as "unknown" so an attacker can't forge it from a direct connection.
TRUSTED_PROXY="false"

# Set to "false" to allow the admin auth cookie over plain HTTP. Use this
# for an IP-only test VPS on :80 where you don't have a TLS terminator
# in front. Lowers security; only acceptable for non-production hosts.
# Leave unset (or set to anything other than "false") for HTTPS deploys.
SECURE_COOKIE="true"
