# Database — SQLite file location
# Local dev: file:./prisma/dev.db
# Production (Docker): file:/app/data/prod.db
DATABASE_URL="file:./prisma/dev.db"

# JWT secret for admin auth cookie. Generate a random 32+ char string.
# On Windows: [Convert]::ToBase64String([byte[]] (1..32 | % { Get-Random -Max 256 }))
JWT_SECRET="change-me-to-a-random-32-plus-char-string"

# Initial admin password used on first login when no password has been set in settings
INITIAL_ADMIN_PASSWORD="changeme"

# Public URL — used for absolute URLs in metadata. Update per environment.
# Local: http://localhost:3000
# Dev:   https://dev.qcffpoll.com
# Prod:  https://qcffpoll.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
