// Quiet Audience Voting — database schema
// SQLite chosen for single-file portability inside a Docker volume.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Film {
  id        String   @id @default(cuid())
  name      String
  school    String
  posterUrl String
  createdAt DateTime @default(now())
  votes     Vote[]
}

model Vote {
  id                  String   @id @default(cuid())
  filmId              String
  film                Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)
  timestamp           DateTime @default(now())
  deviceFingerprint   String
  ipAddress           String
  userAgent           String
  screenWidth         Int?
  screenHeight        Int?
  timezone            String?
  language            String?
  platform            String?
  colorDepth          Int?
  touchSupport        Boolean?
  pixelRatio          Float?
  viewportWidth       Int?
  viewportHeight      Int?
  cookieEnabled       Boolean?
  doNotTrack          String?
  hardwareConcurrency Int?
  deviceMemory        Float?
  rawDeviceJson       String

  @@index([filmId])
  @@index([timestamp])
  @@index([deviceFingerprint])
}

model Setting {
  key   String @id
  value String
}

// A reference profile for a device the admin trusts (e.g. an iPad they
// physically set up at a venue). Other devices casting votes are compared
// to these profiles; non-matching devices are flagged in the admin UI.
model TrustedDeviceProfile {
  id           String   @id @default(cuid())
  label        String
  fingerprint  String?
  userAgent    String
  platform     String?
  screenWidth  Int?
  screenHeight Int?
  createdAt    DateTime @default(now())
}

// Snapshot of a completed voting session. Captured when an admin "resets" the
// votes — the live vote table is wiped, but the totals are preserved here.
// Only the last 5 snapshots are retained; older ones are pruned automatically.
model VoteSnapshot {
  id            String   @id @default(cuid())
  label         String
  createdAt     DateTime @default(now())
  totalVotes    Int
  uniqueDevices Int
  // JSON-serialized array of { filmId, filmName, school, posterUrl, count, percentage }
  filmResults   String
}

// Admin authentication events — every login attempt (success or fail) gets
// a row so the audit log isn't vote-only. Pruned to the last 1000 rows on
// write to keep SQLite small. See roadmap Q3 (#25).
model AuthEvent {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  // "success" | "fail" — kept as a free string so adding new outcomes
  // (e.g. "rate_limited", "origin_rejected") doesn't need a migration.
  outcome   String
  ipAddress String?
  userAgent String?
  // Free-text reason on failure (e.g. "bad_password", "rate_limited",
  // "bad_origin", "server_misconfigured"). Null on success.
  reason    String?

  @@index([timestamp])
  @@index([outcome])
}
